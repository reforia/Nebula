# Nebula Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env
# Both Docker and from-source setups read this file.

# --- Server (used by both Docker and from-source) ---

# Encryption key for secrets vault (REQUIRED)
# Generate yours: openssl rand -hex 32
# Encrypts agent secrets and API tokens. Keep safe — can't decrypt without it.
NEBULA_ENCRYPTION_KEY=

# Data directory (SQLite database, agent workspaces, backups)
# From-source: use ./data (relative to project root)
# Docker: leave as /data (mapped via NEBULA_DATA_DIR volume below)
DATA_DIR=./data

# HTTP port the server listens on
PORT=8080

# External URL of this instance (e.g. http://your-server:8080)
# Required for remote agents and built-in skills. Leave empty for local-only use.
NEBULA_URL=

# Auth provider: "local" (email/password) or "enigma" (Enigma Platform OAuth)
# Self-hosted users should use "local" — no external account required.
AUTH_PROVIDER=local

# Timezone for cron schedules
TZ=UTC

# HTTP proxy (leave empty if not needed)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# --- Docker only (ignored when running from source) ---

# Container user (match your host UID/GID for filesystem access)
NEBULA_UID=1000
NEBULA_GID=1000

# Host port to expose Nebula on (maps to PORT inside the container)
NEBULA_PORT=8080

# Host path for persistent data (mounted as /data inside the container)
NEBULA_DATA_DIR=./data

# Persists CLI auth and config (~/.claude, ~/.config/gemini, etc.)
CLI_HOME_DIR=./cli-home

# Mounts SSH keys into the container (read-only)
SSH_KEYS_DIR=./ssh-keys

# Directory for CLI runtime binaries
RUNTIMES_DIR=./runtimes

# --- Enigma Platform OAuth (only needed when AUTH_PROVIDER=enigma) ---
# OAUTH_REDIRECT_URI=http://your-server:8080/api/auth/callback
# PLATFORM_URL=https://your-platform-url
